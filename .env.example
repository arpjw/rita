# ─── Discord ────────────────────────────────────────────────────────────────
DISCORD_TOKEN=                  # Bot token from Discord Developer Portal

# ─── Anthropic ──────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=              # https://console.anthropic.com

# ─── FRED (Federal Reserve Economic Data) ───────────────────────────────────
FRED_API_KEY=                   # https://fred.stlouisfed.org/docs/api/api_key.html

# ─── Kalshi ─────────────────────────────────────────────────────────────────
KALSHI_API_KEY=                 # https://kalshi.com/
KALSHI_API_SECRET=

# ─── Lumina Regime Backend (optional) ───────────────────────────────────────
# If not set, /regime will return a graceful "not configured" message
LUMINA_API_URL=                 # e.g. http://localhost:8000

# ─── Alert System ───────────────────────────────────────────────────────────
ALERT_POLL_INTERVAL_SECONDS=900 # Default: 15 minutes
MAX_ALERTS_PER_USER=10
